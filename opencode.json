{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "share": "manual",
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://aiapi.isomoes.site/v1",
        "apiKey": "{env:AIAPI_AUTH_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://aiapi.isomoes.site/v1",
        "apiKey": "{env:AIAPI_AUTH_KEY}"
      }
    },
    "google": {
      "options": {
        "baseURL": "https://aiapi.isomoes.site/v1",
        "apiKey": "{env:AIAPI_AUTH_KEY}"
      }
    }
  },
  "plugin": [],
  "tools": {},
  "small_model": "openai/gpt-5.4-mini",
  "agent": {},
  "command": {},
  "formatter": {},
  "lsp": {},
  "permission": {},
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:C7_KEY}"
      },
      "enabled": true
    }
  },
  "instructions": [],
  "disabled_providers": []
}
